<div style="max-width:1200px;margin:0 auto;padding:24px 16px;">
<div class="nc-card">
  <h2 class="nc-title">👥 お客様一覧</h2>

  <%= form_tag users_path, method: 'get', id: 'user-search-form' do %>
    <div style="display:flex;gap:12px;align-items:flex-end;justify-content:center;flex-wrap:wrap;margin-bottom:20px;">
      <div>
        <div style="color:#888;font-size:0.75rem;margin-bottom:4px;">名前</div>
        <%= text_field_tag "search[name]", @user, style: "padding:8px 12px;border:1.5px solid #ddd;border-radius:10px;font-size:0.9rem;width:160px;" %>
      </div>
      <div>
        <div style="color:#888;font-size:0.75rem;margin-bottom:4px;">タイプ</div>
        <%= select :search, :user_type, @user_types.map{|type_name, id| [type_name, id]}, {include_blank: true, selected: @user_type}, style: "padding:8px 12px;border:1.5px solid #ddd;border-radius:10px;font-size:0.9rem;width:160px;" %>
      </div>
      <div><%= submit_tag "検索", name: nil, class: "nc-nav-btn", style: "border-color:#667eea;color:#667eea;cursor:pointer;" %></div>
      <div style="color:#888;font-size:0.85rem;"><%= @users.count %> / <%= User.all.count - 1 %>件</div>
    </div>
  <% end %>

  <div style="overflow-x:auto;">
    <table style="width:100%;min-width:800px;border-collapse:collapse;font-size:0.85rem;">
      <tr style="border-bottom:2px solid #eee;">
        <th style="text-align:left;padding:8px 10px;color:#888;font-weight:600;white-space:nowrap;position:sticky;left:0;background:#fff;z-index:2;">名前</th>
        <th style="text-align:left;padding:8px 10px;color:#888;font-weight:600;">メール</th>
        <th style="text-align:left;padding:8px 10px;color:#888;font-weight:600;white-space:nowrap;">電話</th>
        <th style="text-align:left;padding:8px 10px;color:#888;font-weight:600;white-space:nowrap;">生年月日</th>
        <th style="text-align:left;padding:8px 4px;color:#888;font-weight:600;white-space:nowrap;">性別</th>
        <th style="text-align:left;padding:8px 4px;color:#888;font-weight:600;white-space:nowrap;">紹介者</th>
        <th style="text-align:left;padding:8px 4px;color:#888;font-weight:600;white-space:nowrap;">タイプ</th>
        <th style="padding:8px 4px;white-space:nowrap;"></th>
      </tr>
      <% @users.each do |user| %>
        <tr style="border-bottom:1px solid #f0f0f0;">
          <td style="padding:8px 10px;white-space:nowrap;position:sticky;left:0;background:#fff;z-index:1;"><%= link_to user.name, "/users/#{user.id}/edit", style: "color:#2563eb;font-weight:600;text-decoration:none;" %></td>
          <td style="padding:8px 10px;word-break:break-all;"><a href="mailto:<%= user.email %>" data-turbo="false" style="color:#2563eb;text-decoration:none;"><%= user.email %></a></td>
          <td style="padding:8px 10px;white-space:nowrap;"><%= user.tel %></td>
          <td style="padding:8px 10px;white-space:nowrap;"><%= user.birthday %></td>
          <td style="padding:8px 4px;"><%= Global::GENDER[user.gender] %></td>
          <td style="padding:8px 4px;"><%= user.introducer %></td>
          <td style="padding:8px 4px;">
            <% if user.user_type.present? %>
              <% type_name = UserType.find_by(id: user.user_type)&.type_name || '---' %>
              <span style="padding:2px 8px;border-radius:12px;font-size:0.7rem;font-weight:600;
                <% if user.user_type == '1' %>background:#e8f5e9;color:#2e7d32;
                <% elsif user.user_type == '11' %>background:#fff3cd;color:#856404;
                <% elsif user.user_type == '12' %>background:#e3f2fd;color:#1565c0;
                <% else %>background:#f5f5f5;color:#555;<% end %>"><%= type_name %></span>
            <% else %><span style="color:#ccc;">---</span><% end %>
          </td>
          <td style="padding:8px 10px;">
            <%= link_to "users/#{user.id}", data: { confirm: "#{user.name}様を本当に削除しますか？" }, method: :delete, style: "color:#e74c3c;font-size:0.75rem;text-decoration:none;" do %>削除<% end %>
          </td>
        </tr>
      <% end %>
    </table>
  </div>
</div>
</div>

<script>
// 検索ボタンクリック時のみ検索（自動検索なし）
</script>
