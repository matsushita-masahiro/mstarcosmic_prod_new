<div class="nc-container">
<div class="nc-card">
  <h2 class="nc-title">📋 全スタッフ出勤スケジュール</h2>
  <% if current_user.user_type == "1" %>
    <p class="nc-subtitle"><%= link_to "← スタッフ管理に戻る", "/admin/staffs", style: "color:#667eea;" %></p>
  <% end %>

  <div class="nc-week-nav">
    <div class="nc-nav-left">
      <% if @start_date > Date.today %>
        <%= link_to "/all_schedules?calender_start_date=#{@start_date - 7}", class: "nc-nav-btn" do %>← 前週<% end %>
      <% end %>
    </div>
    <div class="nc-nav-center"><span class="nc-week-range"><%= @start_date.strftime("%-m/%-d") %> 〜 <%= (@start_date + 6).strftime("%-m/%-d") %></span></div>
    <div class="nc-nav-right">
      <% if @start_date <= (Date.today + 70) %>
        <%= link_to "/all_schedules?calender_start_date=#{@start_date + 7}", class: "nc-nav-btn" do %>翌週 →<% end %>
      <% end %>
    </div>
  </div>

  <table class="nc-table">
    <thead><tr><th></th>
      <% 7.times do |i| %>
        <% d = (@start_date + i).to_date %>
        <% day_class = d == Date.current ? 'nc-today' : (d.wday == 6 ? 'nc-sat' : (d.wday == 0 ? 'nc-sun' : '')) %>
        <th class="<%= day_class %>"><span class="nc-date-num"><%= d.day %></span><span class="nc-date-day"><%= %w[日 月 火 水 木 金 土][d.wday] %></span></th>
      <% end %>
    </tr></thead>
    <tbody>
      <% 24.times do |t| %>
        <tr><th><%= display_time(10 + t * 0.5) %></th>
          <% 7.times do |k| %>
            <% d = (@start_date + k).to_date; names = attendance_staff(d, 10 + t * 0.5) %>
            <td>
              <% if names == ["=="] %><span class="nc-icon nc-icon-empty"></span>
              <% else %><% names.each do |n| %><%
                colors = {
                  '聖子' => 'background:#f0f0f0;color:#1a1a1a;',
                  '悠綺' => 'background:#e8f5e9;color:#2e7d32;',
                  '花香' => 'background:#fce4ec;color:#ad1457;',
                  '由香' => 'background:#e3f2fd;color:#1565c0;',
                  'みほ' => 'background:#ffebee;color:#c62828;',
                  '実穂' => 'background:#ffebee;color:#c62828;',
                  '奈緒' => 'background:#fff3e0;color:#e65100;',
                  '夏子' => 'background:#f3e5f5;color:#7b1fa2;',
                  '可奈' => 'background:#e0f7fa;color:#00695c;',
                  '佐藤' => 'background:#fbe9e7;color:#bf360c;',
                  '光子' => 'background:#fff9c4;color:#f57f17;',
                  'まさ' => 'background:#fff9c4;color:#f57f17;',
                  '青木正隆' => 'background:#fff9c4;color:#f57f17;',
                }
                style = colors[n] || 'background:#f5f5f5;color:#555;'
              %><span class="nc-staff-badge" style="<%= style %>"><%= n %></span><% end %><% end %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
</div>
