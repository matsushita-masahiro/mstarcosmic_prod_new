<div class="nc-container">
<div class="nc-card">
  <h2 class="nc-title">📋 スケジュール登録（<%= @staff.name %>）</h2>
  <p class="nc-subtitle"><%= link_to "← スタッフ管理に戻る", "/admin/staffs", style: "color:#667eea;" %></p>

  <% if user_signed_in? && current_user.user_type == "1" %>
    <div class="nc-actions">
      <% if @staff.active_flag %>
        <%= link_to "予約カレンダーからはずす", "/staffs/#{@staff.id}/nonactivate", method: "patch", class: "nc-nav-btn nc-nav-btn-danger" %>
      <% else %>
        <%= link_to "予約カレンダーに入れる", "/staffs/#{@staff.id}/activate", method: "patch", class: "nc-nav-btn", style: "border-color:#27ae60;color:#27ae60;" %>
      <% end %>
    </div>
  <% end %>

  <%= render 'schedule_calender' %>

  <% if admin_user? %>
    <div class="nc-actions" style="margin-top:24px;">
      <% if @staff.dismiss_flag == false %>
        <%= link_to "スタッフを解任", "/admin/staffs/#{@staff.id}",
            data: { turbo_method: :delete, turbo_confirm: "【確認】『#{@staff.name}』の全ての出勤カレンダーも削除されますが本当に解任されますか？" },
            class: "nc-nav-btn nc-nav-btn-danger" %>
      <% else %>
        <%= link_to "再度スタッフにする", "/admin/staffs/#{@staff.id}",
            data: { turbo_method: :patch, turbo_confirm: "【確認】『#{@staff.name}』を再度スタッフに就任させますか？" },
            class: "nc-nav-btn" %>
      <% end %>
    </div>
  <% end %>
</div>
</div>
