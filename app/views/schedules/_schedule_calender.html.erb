<div class="nc-week-nav">
  <div class="nc-nav-left">
    <% if @start_date > Date.today %>
      <%= link_to "/admin/staffs/#{@staff.id}/schedules?calender_start_date=#{@start_date - 7}", class: "nc-nav-btn" do %>← 前週<% end %>
    <% end %>
  </div>
  <div class="nc-nav-center"><span class="nc-week-range"><%= @start_date.strftime("%-m/%-d") %> 〜 <%= (@start_date + 6).strftime("%-m/%-d") %></span></div>
  <div class="nc-nav-right">
    <% if @start_date <= (Date.today + 70) %>
      <%= link_to "/admin/staffs/#{@staff.id}/schedules?calender_start_date=#{@start_date + 7}", class: "nc-nav-btn" do %>翌週 →<% end %>
    <% end %>
  </div>
</div>

<%= form_tag staff_schedules_path(@staff), method: "post" do %>
  <input type="hidden" name="calender_start_date" value="<%= @start_date %>">
  <div class="nc-actions"><%= submit_tag "スケジュール登録", class: "nc-nav-btn", style: "border-color:#667eea;color:#667eea;cursor:pointer;" %></div>

  <table class="nc-table">
    <thead><tr><th></th>
      <% 7.times do |i| %>
        <% d = (@start_date + i).to_date %>
        <% day_class = d == Date.current ? 'nc-today' : (d.wday == 6 ? 'nc-sat' : (d.wday == 0 ? 'nc-sun' : '')) %>
        <th class="<%= day_class %>">
          <span class="nc-date-num"><%= d.day %></span><span class="nc-date-day"><%= %w[日 月 火 水 木 金 土][d.wday] %></span>
          <% unless d == Date.current %><div style="margin-top:4px;"><input type="checkbox" id="day_allChecked_<%= i %>" class="nc-check"></div><% end %>
        </th>
      <% end %>
    </tr></thead>
    <tbody id="boxes">
      <% 24.times do |t| %>
        <% space = 10 + t * 0.5 %>
        <tr><th><%= display_time(space) %></th>
          <% 7.times do |k| %>
            <% d = (@start_date + k).to_date %>
            <% if d == Date.current %>
              <td><span class="nc-icon nc-icon-empty"></span></td>
            <% else %>
              <% checked = Schedule.find_by(staff_id: @staff.id, schedule_date: d, schedule_space: space) %>
              <td class="nc-check-cell">
                <input type="checkbox" <%= 'checked' if checked %> name="staff[schedule][]" value="<%= d %>&<%= space %>&1" class="nc-check day_check_<%= k %>">
              </td>
            <% end %>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="nc-actions"><%= submit_tag "スケジュール登録", class: "nc-nav-btn", style: "border-color:#667eea;color:#667eea;cursor:pointer;" %></div>
<% end %>

<script>
document.querySelectorAll('[id^="day_allChecked_"]').forEach(function(el) {
  el.addEventListener('change', function() {
    var i = this.id.replace('day_allChecked_', '');
    document.querySelectorAll('.day_check_' + i).forEach(function(c) { c.checked = el.checked; });
  });
});
</script>
