<div id="staff-index">
    <h3>出勤カレンダー入力・変更</h3>
    <% if user_signed_in? && current_user.user_type == "1" %>
      <%= link_to "スタッフ登録・変更", new_staff_path, class: "btn btn-primary" %><br>
    <% end %>
    <%= link_to "全スケジュール確認", all_schedules_path, class: "all-schedules" %>
    
    <ul class="staff-ul">
      <% if current_user.user_type == "1" %>
        <% @staffs.each do |staff| %>
            <% if staff.dismiss_flag == false %>
               <li><%= link_to staff.name, new_staff_schedules_path(staff_id: staff.id) %></li>
            <% else %>
               <li>
                 <span class="dismissal-link"><%= staff.name %></span>
                 <%= link_to "復帰", staff_path(staff), method: :patch, data: { confirm: "#{staff.name}をスタッフに復帰させますか？" }, class: "restore-btn" %>
                 <%= button_to "完全削除", "/admin/staffs/#{staff.id}", method: :post, data: { turbo_confirm: "#{staff.name}を完全に削除しますか？\nこの操作は取り消せません。\n予約履歴のスタッフ情報も失われます。" }, class: "fire-btn", form: { style: "display:inline;" } %>
               </li>
            <% end %>
        <% end %>
      <% elsif current_user.user_type == "10" && Staff.find_by(user_id: current_user.id) %>
        <li><%= link_to Staff.find_by(user_id: current_user.id).name, new_staff_schedules_path(staff_id: Staff.find_by(user_id: current_user.id).id) %></li>
      <% else %>
        <li>スタッフ登録処理未完了です</li>
      <% end %>
    </ul>
</div>

<style>
  #staff-index .all-schedules {
    font-size: 18px;
    margin-bottom: 10px;
    color: green;
  }
  
  .dismissal-link {
    color: red;
  }
  
  .restore-btn {
    margin-left: 10px;
    font-size: 0.85rem;
    color: #16a34a;
    text-decoration: none;
    border: 1px solid #16a34a;
    padding: 2px 10px;
    border-radius: 6px;
  }
  
  .restore-btn:hover {
    background: #16a34a;
    color: #fff;
  }
  
  .fire-btn {
    margin-left: 6px;
    font-size: 0.8rem;
    color: #fff;
    background: #dc2626;
    text-decoration: none;
    border: none;
    padding: 2px 10px;
    border-radius: 6px;
    cursor: pointer;
  }
  
  .fire-btn:hover {
    background: #b91c1c;
  }
  
  @media (max-width: 414px) {
      #staff-index .all-schedules {
        font-size: 15px;
      }
  }
</style>