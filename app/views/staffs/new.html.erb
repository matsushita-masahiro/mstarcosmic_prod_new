<div class="staff-mgmt">

  <div style="margin-bottom: 16px;">
    <%= link_to "← 出勤カレンダー入力・変更に戻る", "/admin/staffs", class: "staff-back-btn" %>
  </div>

  <!-- スタッフ登録 -->
  <div class="staff-section">
    <h3 class="staff-section-title">👤 スタッフ登録</h3>
    <%= form_with model: @staff, url: "/admin/staffs", class: "staff-form" do |f| %>
      <div class="staff-field">
        <label class="staff-label">スタッフ名</label>
        <%= f.text_field :name, required: true, class: "staff-input", placeholder: "ひらがな" %>
      </div>
      <div class="staff-field">
        <label class="staff-label">スタッフ名漢字</label>
        <%= f.text_field :name_kanji, class: "staff-input", placeholder: "漢字" %>
      </div>
      <div class="staff-field">
        <label class="staff-label">担当施術</label>
        <%= f.fields_for :staff_machine_relations do |smr| %>
          <div class="staff-radio-group">
            <label class="staff-radio-item"><%= smr.radio_button :machine, "h", checked: true %> ホリスティック</label>
            <label class="staff-radio-item"><%= smr.radio_button :machine, "e" %> エステ</label>
            <label class="staff-radio-item"><%= smr.radio_button :machine, "stem" %> 幹細胞</label>
            <label class="staff-radio-item"><%= smr.radio_button :machine, "b" %> 鍼・整体</label>
            <label class="staff-radio-item"><%= smr.radio_button :machine, "o" %> その他</label>
          </div>
        <% end %>
      </div>
      <div class="staff-actions">
        <%= f.submit "登録", class: "staff-btn staff-btn-primary" %>
      </div>
    <% end %>
  </div>

  <!-- 担当施術修正 -->
  <div class="staff-section">
    <h3 class="staff-section-title">✏️ 担当施術修正</h3>
    <%= form_with model: @staff_machine_relation, url: admin_staffs_staff_machine_relations_path, method: :patch, class: "staff-form", id: "staff-machine-form" do |g| %>
      <div class="staff-field">
        <label class="staff-label">スタッフ選択</label>
        <div class="staff-card-list">
          <% @staffs.each do |staff| %>
            <label class="staff-card <%= 'staff-card-inactive' unless staff.active_flag %>" for="staff_machine_relation_staff_id_<%= staff.id %>">
              <%= g.radio_button :staff_id, staff.id, class: "staff-card-radio", id: "staff_machine_relation_staff_id_#{staff.id}" %>
              <div class="staff-card-body">
                <div class="staff-card-name"><%= staff.name_kanji.present? ? staff.name_kanji : staff.name %></div>
                <div class="staff-card-sub"><%= staff.name %></div>
                <div class="staff-card-machines">
                  <% staff.staff_machine_relations.each do |rel| %>
                    <span class="staff-tag staff-tag-<%= rel.machine %>"><%= { 'h' => 'ホリスティック', 'w' => 'ウェルビーイング', 'e' => 'エステ', 'stem' => '幹細胞', 'b' => '鍼・整体', 'o' => 'その他', 'shinkyu' => '鍼灸', 'seitai' => '整体' }[rel.machine] || rel.machine %></span>
                  <% end %>
                </div>
              </div>
              <div class="staff-card-actions">
                <span class="staff-edit-btn" onclick="event.preventDefault(); event.stopPropagation(); showEditForm(<%= staff.id %>)">編集</span>
                <span class="staff-dismiss-btn" onclick="event.preventDefault(); event.stopPropagation(); dismissStaff(<%= staff.id %>, '<%= staff.name %>')">スタッフ解任</span>
              </div>
            </label>
          <% end %>
        </div>
      </div>
      <div class="staff-field">
        <label class="staff-label">担当施術（複数選択可）</label>
        <div class="staff-check-group">
          <% Machine.where.not(short_word: 'w').each do |machine| %>
            <% label = { 'h' => 'ホリスティック', 'w' => 'ウェルビーイング', 'e' => 'エステ', 'stem' => '幹細胞', 'b' => '鍼・整体', 'o' => 'その他' }[machine.short_word] || machine.name %>
            <label class="staff-check-item">
              <%= g.check_box :machine, { multiple: true, include_hidden: false }, machine.short_word, nil %> <%= label %>
            </label>
          <% end %>
        </div>
      </div>
      <div class="staff-actions">
        <%= g.submit "修正を保存", class: "staff-btn staff-btn-success" %>
      </div>
    <% end %>

    <!-- 編集フォーム（メインフォームの外） -->
    <% @staffs.each do |staff| %>
      <div id="edit-form-<%= staff.id %>" class="staff-edit-form" style="display: none;">
        <%= form_with model: staff, url: update_info_staff_path(staff), method: :patch, class: "staff-form" do |ef| %>
          <div class="staff-field">
            <label class="staff-label">スタッフ名（ひらがな）</label>
            <%= ef.text_field :name, required: true, class: "staff-input", value: staff.name %>
          </div>
          <div class="staff-field">
            <label class="staff-label">スタッフ名（漢字）</label>
            <%= ef.text_field :name_kanji, class: "staff-input", value: staff.name_kanji %>
          </div>
          <div class="staff-field">
            <label class="staff-label">ステータス</label>
            <div class="staff-toggle">
              <%= ef.hidden_field :active_flag, value: "0" %>
              <label class="staff-toggle-label">
                <%= ef.check_box :active_flag, { checked: staff.active_flag, class: "staff-toggle-input" }, "1", "0" %>
                <span class="staff-toggle-slider"></span>
                <span class="staff-toggle-text"><%= staff.active_flag ? '有効' : '無効' %></span>
              </label>
            </div>
          </div>
          <div class="staff-actions" style="display: flex; gap: 8px; justify-content: center;">
            <%= ef.submit "保存", class: "staff-btn staff-btn-success" %>
            <button type="button" class="staff-btn staff-btn-cancel" onclick="hideEditForm(<%= staff.id %>)">キャンセル</button>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- 解任用の隠しフォーム（メインフォームの外） -->
    <% @staffs.each do |staff| %>
      <%= form_with url: "/admin/staffs/#{staff.id}", method: :delete, id: "dismiss-form-#{staff.id}", style: "display:none;" do %>
      <% end %>
    <% end %>
  </div>

</div>

<script>
function showEditForm(staffId) {
  document.querySelectorAll('.staff-edit-form').forEach(function(form) {
    form.style.display = 'none';
  });
  var form = document.getElementById('edit-form-' + staffId);
  if (form) {
    form.style.display = 'block';
  }
}

function hideEditForm(staffId) {
  var form = document.getElementById('edit-form-' + staffId);
  if (form) {
    form.style.display = 'none';
  }
}

function dismissStaff(staffId, staffName) {
  if (confirm(staffName + "を解任しますか？\nスケジュールと担当施術も削除されます。\nこの操作は取り消せません。")) {
    document.getElementById('dismiss-form-' + staffId).requestSubmit();
  }
}
</script>
