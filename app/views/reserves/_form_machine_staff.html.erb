<div class="modal-dialog modal-lg" style="z-index: 10000;">
  <div class="modal-content" style="border-radius:16px;border:none;box-shadow:0 8px 32px rgba(0,0,0,0.12);">
    <div class="modal-header" style="border-bottom:none;padding:20px 24px 0;">
      <h3 style="font-weight:700;font-size:1.2rem;color:#1a1a2e;">予約確認</h3>
      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="background:none;border:1px solid #ddd;border-radius:50%;width:32px;height:32px;font-size:0.7rem;"></button>
    </div>
    <div style="padding:16px 24px 24px;">
      <%= form_for @reserve do |f| %>

        <div style="background:#f8f9fa;border-radius:12px;padding:16px;margin-bottom:16px;">
          <div style="display:flex;border-bottom:1px solid #eee;padding:10px 0;">
            <span style="width:70px;color:#888;font-size:0.85rem;">氏名</span>
            <span style="font-weight:600;color:#1a1a2e;"><%= current_user.name %></span>
          </div>
          <div style="display:flex;border-bottom:1px solid #eee;padding:10px 0;">
            <span style="width:70px;color:#888;font-size:0.85rem;">性別</span>
            <span><%= Global::GENDER[current_user.gender] %></span>
          </div>
          <div style="display:flex;border-bottom:1px solid #eee;padding:10px 0;">
            <span style="width:70px;color:#888;font-size:0.85rem;">電話</span>
            <span><%= current_user.tel %></span>
          </div>
          <div style="display:flex;border-bottom:1px solid #eee;padding:10px 0;">
            <span style="width:70px;color:#888;font-size:0.85rem;">日時</span>
            <span style="color:#2563eb;font-weight:600;"><%= @date.to_date.strftime("%Y年%-m月%-d日") %>（<%= Global::WEEKDAY[@date.to_date.wday] %>）<%= display_time(@frame.to_f) %>〜</span>
          </div>
          <div style="display:flex;border-bottom:1px solid #eee;padding:10px 0;">
            <span style="width:70px;color:#888;font-size:0.85rem;">サービス</span>
            <span style="font-weight:600;"><%= { 'h' => 'ホリスティック', 'e' => 'エステ', 'seitai' => '整体' }[@machine] || 'ホリスティック' %></span>
          </div>
          <div style="display:flex;padding:10px 0;">
            <span style="width:70px;color:#888;font-size:0.85rem;">スタッフ</span>
            <span style="flex:1;">
              <% service_name = { 'h' => 'holistic', 'e' => 'esute', 'seitai' => 'seitai' }[@machine] || 'holistic' %>
              <% available = AvailabilityService.new(service_name, @date.to_date, num_days: 1, user_signed_in: true).available_staff(@date.to_date, format('%02d:%02d', @frame.to_f.to_i, ((@frame.to_f % 1) * 60).to_i), duration_minutes: 60) %>
              <% if @machine == 'e' || @machine == 'seitai' %>
                <%# エステ・整体は担当スタッフ固定 %>
                <% staff = available.first %>
                <% if staff %>
                  <span style="font-weight:600;"><%= staff.name_kanji.present? ? staff.name_kanji : staff.name %></span>
                  <input type="hidden" name="reserve[staff_id]" value="<%= staff.id %>">
                <% else %>
                  <span style="color:#e74c3c;">担当スタッフが出勤していません</span>
                  <input type="hidden" name="reserve[staff_id]" value="0">
                <% end %>
              <% else %>
                <select name="reserve[staff_id]" id="staff-select" style="width:100%;padding:8px 12px;border:1.5px solid #ddd;border-radius:10px;font-size:0.9rem;background:#fff;" onchange="updateNominationFee(this)">
                  <option value="0">指名なし</option>
                  <% available.select { |s| s.nomination_fee > 0 }.each do |s| %>
                    <option value="<%= s.id %>" data-fee="<%= s.nomination_fee %>"><%= s.name %>（+<%= number_with_delimiter(s.nomination_fee) %>円）</option>
                  <% end %>
                </select>
                <div id="nomination-fee-notice" style="color:#e74c3c;margin-top:4px;font-size:0.8rem;display:none;">指名料: <span id="fee-amount"></span>円</div>
              <% end %>
            </span>
          </div>
        </div>

        <div style="margin-bottom:16px;">
          <div style="color:#888;font-size:0.8rem;margin-bottom:6px;">予約時間</div>
          <% if @machine == 'e' %>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <label style="padding:8px 20px;border-radius:20px;background:#fff3cd;color:#856404;font-size:0.85rem;font-weight:600;cursor:pointer;">
                <%= f.radio_button :frames, "60", checked: true %> 60分
              </label>
              <label style="padding:8px 20px;border-radius:20px;border:1.5px solid #ddd;font-size:0.85rem;font-weight:600;cursor:pointer;">
                <%= f.radio_button :frames, "90" %> 90分
              </label>
              <label style="padding:8px 20px;border-radius:20px;border:1.5px solid #ddd;font-size:0.85rem;font-weight:600;cursor:pointer;">
                <%= f.radio_button :frames, "120" %> 120分
              </label>
              <label style="padding:8px 20px;border-radius:20px;border:1.5px solid #ddd;font-size:0.85rem;font-weight:600;cursor:pointer;">
                <%= f.radio_button :frames, "150" %> 150分
              </label>
            </div>
          <% elsif @machine == 'seitai' %>
            <div style="padding:10px 16px;background:#fff3cd;color:#856404;border-radius:10px;font-weight:600;font-size:0.9rem;">60分</div>
            <%= f.hidden_field :frames, value: "60" %>
          <% elsif user_signed_in? && admin_user? %>
            <div style="display:flex;gap:8px;">
              <label style="padding:8px 20px;border-radius:20px;border:1.5px solid #ddd;font-size:0.85rem;font-weight:600;cursor:pointer;">
                <%= f.radio_button :frames, "30" %> 30分
              </label>
              <label style="padding:8px 20px;border-radius:20px;background:#fff3cd;color:#856404;font-size:0.85rem;font-weight:600;cursor:pointer;">
                <%= f.radio_button :frames, "60", checked: true %> 60分
              </label>
            </div>
          <% else %>
            <div style="padding:10px 16px;background:#fff3cd;color:#856404;border-radius:10px;font-weight:600;font-size:0.9rem;">60分</div>
            <%= f.hidden_field :frames, value: "60" %>
          <% end %>
        </div>

        <div style="margin-bottom:16px;">
          <div style="color:#888;font-size:0.8rem;margin-bottom:6px;">備考</div>
          <%= f.text_area :remarks, style: "width:100%;padding:10px 12px;border:1.5px solid #ddd;border-radius:10px;font-size:0.9rem;min-height:80px;resize:vertical;", placeholder: "ご要望があればご記入ください" %>
        </div>

        <%= f.hidden_field :reserved_date, value: @date %>
        <%= f.hidden_field :reserved_space, value: @frame %>
        <%= f.hidden_field :start_date, value: @start_date %>
        <%= f.hidden_field :user_id, value: current_user.id %>
        <%= f.hidden_field :machine, value: @machine %>

        <div style="display:flex;gap:12px;justify-content:center;padding-top:8px;">
          <button type="button" data-bs-dismiss="modal" style="padding:10px 28px;border-radius:24px;border:1.5px solid #ddd;background:#fff;color:#333;font-size:0.9rem;font-weight:500;cursor:pointer;">戻る</button>
          <%= f.submit "予約を確定する", style: "padding:10px 28px;border-radius:24px;border:none;background:#2563eb;color:#fff;font-size:0.9rem;font-weight:600;cursor:pointer;" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function updateNominationFee(select) {
  var fee = select.options[select.selectedIndex].getAttribute('data-fee');
  var notice = document.getElementById('nomination-fee-notice');
  var amount = document.getElementById('fee-amount');
  if (fee && parseInt(fee) > 0) {
    amount.textContent = parseInt(fee).toLocaleString();
    notice.style.display = 'block';
  } else {
    notice.style.display = 'none';
  }
}
</script>
